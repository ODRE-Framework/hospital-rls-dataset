{
  "@context": [
    "http://www.w3.org/ns/odrl.jsonld",
    "https://raw.githubusercontent.com/ODRE-Framework/hospital-rls-dataset/refs/heads/main/context.json"
  ],
  "@type": "odrl:Set",
  "uid": "ex:dc851af8-9798-4221-b79b-e0cbf6216d81",
  "rdfs:label" : "Policy 04",
  "permission": [
    {
      "@type": "odrl:Permission",
      "assigner": {
        "@type": [
          "odrl:Party",
          "sch:Hospital"
        ],
        "uid": "ex:hopital-organization",
        "rdfs:description" : "A specific hospital that owns this policy"
      },
      "assignee": {
        "@type": [
          "odrl:PartyCollection",
          "sch:Patient"
        ],
        "uid": "ex:groups/patients",
        "rdfs:description": "Anyone who is a patient of the hospital"
      },
      "action": "read",
      "target": "db:ClinicalRecords",
      "constraint": [
        {
          "@type": "odrl:Constraint",
          "leftOperand": "ex:request/P04/param-identity",
          "operator": "odrl:eq",
          "rightOperand": "db:ClinicalRecords?patient_id"
        },{
          "@type": "odrl:Constraint",
          "leftOperand": "ex:request/P04/param-record",
          "operator": "odrl:eq",
          "rightOperand": "db:ClinicalRecords?record_id"
        }
      ]
    }
  ]
}
